# =============================================================
# 复制这个文件为 .env，然后填写你自己的值
#   cp .env.example .env
# =============================================================

# 对外暴露的端口（如果你用 Nginx/Caddy 反代，这个端口只需要给反代访问）
APP_PORT=8000

# PostgreSQL
POSTGRES_USER=bookmark
POSTGRES_PASSWORD=please-change-this-password
POSTGRES_DB=bookmark
POSTGRES_REQUIRE_SSL=false

# API Token 签名密钥（用于浏览器插件等外部访问）
# 生成方式：openssl rand -hex 32
API_TOKEN_SECRET=please-generate-a-random-secret-key
API_TOKEN_EXPIRE=1h

# 图片压缩质量（WebP 转换，0.0-100.0，数值越大质量越好、体积越大）
IMAGE_QUALITY=80.0
